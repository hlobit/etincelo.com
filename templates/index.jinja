{% extends "base.jinja" %}

{% block title %}Etincelo | La pop louange franciscaine{% endblock %}

{% block content %}
  <section>
    <header>
      <h1>Nous sommes Etincelo.</h1>
      <aside>Groupe de <em>pop louange franciscaine</em>, en activité depuis 2013.</aside>
      <p><small>Pour en savoir plus, rendez-vous la page <em><a href="qui-sommes-nous.html">Qui sommes-nous&nbsp;?</a></em></small>
    </header>
    <article class="highlight">
      <h3><em>François notre frère</em>&nbsp;: bientôt un album pour l'année jubilaire franciscaine&nbsp;!</h3>
      <p>L’année 2026 offre une occasion très spéciale pour que la louange franciscaine résonne&nbsp;: <strong>l’année jubilaire franciscaine</strong>, par laquelle toute l’Église célèbre les 800 ans de la mort du petit pauvre d’Assise - si cher à nos yeux et à nos cœurs.
      <p>Et c’est à ce <em>moment clé</em> que nous avons la joie de travailler sur <strong>un nouvel album</strong>, qui s’intitulera <em>François notre frère</em>, en collaboration fraternelle avec nos amis les musiciens de <a target="_blank" href="https://reparemoneglise.com/musique/">Répare mon Église</a>. 
      <p>Cet album, prévu pour le mois de septembre, sera composé de 10 chants qui mettront à l'honneur <strong>les textes et le charisme de saint François et sainte Claire</strong>. Hâte de vous partager ces textes et arrangements qui nous feront redécouvrir ensemble cet héritage, 800 ans après&nbsp;!
      <p>Plus d'informations sur <a href="francois-notre-frere.html">la page <em>François notre frére</em></a>, pour en savoir plus, et pour savoir <strong>comment nous soutenir</strong> dans la réalisation de ce projet franciscain&nbsp;! 
      <div style="text-align: center">
        <a href="francois-notre-frere.html"><img style="max-height: 600px; max-width: 100%" src="images/stantoine.photo.jpg" /></a>
      </div>
      <p><em>Pace e bene&nbsp;!</em> 
    </article>
    <article class="highlight">
      <p><em>Nous vous invitons, dès aujourd'hui, à (re)plonger avec Marie dans la prière, à travers les chants de l'album <strong>Nazaréenne</strong> ci-dessous.</em>
      <!-- Elfsight Audio Player | Nazaréenne -->
      <script src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-994cf045-b739-4948-b95e-9d919bb291e1" data-elfsight-app-lazy></div>
    </article>
  </section>
  <section>
    <article id="newsletters">
    <h3>La newsletter</h3>
    <form id="newsletter" name="contact" method="POST" data-netlify="true" action="/api/newsletter-subscribe">
      <div class="field grow">
        <div class="control">
          <input id="inputEmail" class="input" type="email" name="email" placeholder="Entrez votre adresse email pour vous inscrire..." autocomplete="off">
        </div>
      </div>
      <div class="field" aria-hidden="true">
        <div class="control">
          <input id="inputVerifyEmail" type="text" name="verifyEmail" placeholder="Verify email" tabindex="-1" value="" autocomplete="off">
        </div>
      </div>
      <div class="field">
        <div class="control">
          <button id="button" type="submit" class="button is-primary">Envoyer</button>
        </div>
      </div>
    </form>
    <ul>
      {% for newsletter in newsletters %}
      <li>
        <a href="{{ newsletter['archive_url_long'] }}" target="_blank">
          <p class="date type">{{ newsletter['send_time'] }}</p>
          <p class="subtitle">{{ newsletter['subject'] }}</p>
        </a>
      </li>
      {% endfor %}
    </ul>
    </article>
  </section>
{% endblock %}

{% block script %}
<script>
  var form = document.getElementById('newsletter');

  form.addEventListener("submit", function(e) {
    e.preventDefault();
    var email = document.getElementById('inputEmail').value;
    var verifyEmail = document.getElementById('inputVerifyEmail').value;
    if (verifyEmail) {
      return false;
    }
    submitSubscription({email})
  });

  function submitSubscription(data) {
    fetch(form.action, {
      method: form.method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    }).then(function(response) {
      return response.json();
    }).then(function(data) {
      var submitButton = document.getElementById('button');
      submitButton.innerText = 'Envoyé !'
      document.getElementById('inputEmail').value = '';
      submitButton.disabled = true
    });
  };
</script>
{% endblock %}
